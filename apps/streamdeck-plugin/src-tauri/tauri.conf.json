{
  "package": {
    "productName": "ai-engineering-hub-streamdeck",
    "version": "1.0.0"
  },
  "tauri": {
    "windows": [
      {
        "url": "index.html",
        "transparent": false,
        "fullscreen": false,
        "width": 300,
        "height": 600,
        "title": "AI Engineering Hub – Stream Deck"
      }
    ],
    "security": {
      "csp": null
    },
    "allowlist": {
      "http": {
        "all": true
      },
      "fs": {
        "all": false
      },
      "dialog": {
        "all": false
      }
    },
    "bundle": {
      "identifier": "com.example.ai_engineering_hub_streamdeck",
      "icon": [
        "icons/icon.png"
      ],
      "targets": "all"
    }
  }
}