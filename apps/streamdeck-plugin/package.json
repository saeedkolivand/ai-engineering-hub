{
  "name": "ai-engineering-monitor-plugin",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "sd:validate": "streamdeck validate com.aiengineering.monitor.sdPlugin",
    "sd:pack": "tsup && streamdeck pack com.aiengineering.monitor.sdPlugin --force",
    "sd:link": "streamdeck link com.aiengineering.monitor.sdPlugin"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.1.0",
    "shared-events": "workspace:*",
    "shared-sdk": "workspace:*",
    "shared-types": "workspace:*"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
