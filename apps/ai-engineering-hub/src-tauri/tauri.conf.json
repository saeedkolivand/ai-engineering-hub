{
  "package": {
    "productName": "AI Engineering Hub",
    "version": "0.1.0"
  },
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../src/frontend/dist",
    "distDir": "../src/frontend/dist"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "shell": {
        "all": true
      },
      "protocol": {
        "asset": true,
        "app": true
      }
    },
    "window": {
      "title": "AI Engineering Hub",
      "width": 1200,
      "height": 800,
      "resizable": true,
      "fullscreen": false
    },
    "security": {
      "csp": null
    }
  }
}