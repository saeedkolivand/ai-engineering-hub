{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Engineering Hub",
  "version": "0.5.0",
  "identifier": "com.aiengineering.hub",
  "build": {
    "frontendDist": "../src/frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter ai-engineering-hub-frontend dev",
    "beforeBuildCommand": "pnpm --filter ai-engineering-hub-frontend build"
  },
  "app": {
    "windows": [
      {
        "title": "AI Engineering Hub",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/saeedkolivand/ai-engineering-hub/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFMUYyMEY1NUU2REQ1QTcKUldTbjFXMWU5U0FmTHFtWEFsNjF6SkhjUzNNeW51OXdWekk0MWJIQXlDWGs3Znl5TXB2Y2ZPWXEK"
    },
    "deep-link": {
      "schemes": [
        "aeh"
      ]
    }
  }
}
