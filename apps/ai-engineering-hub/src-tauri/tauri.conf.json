{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Engineering Hub",
  "version": "0.1.0",
  "identifier": "com.aiengineering.hub",
  "build": {
    "frontendDist": "../src/frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter ai-engineering-hub-frontend dev",
    "beforeBuildCommand": "pnpm --filter ai-engineering-hub-frontend build"
  },
  "app": {
    "windows": [
      {
        "title": "AI Engineering Hub",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
